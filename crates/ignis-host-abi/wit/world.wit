package ignis:platform;

interface sqlite {
    record statement {
        sql: string,
        params: list<string>,
    }

    record row {
        values: list<string>,
    }

    record query-result {
        columns: list<string>,
        rows: list<row>,
    }

    variant sqlite-value {
        null,
        integer(s64),
        real(f64),
        text(string),
        blob(list<u8>),
    }

    record typed-row {
        values: list<sqlite-value>,
    }

    record typed-query-result {
        columns: list<string>,
        rows: list<typed-row>,
    }

    execute: func(sql: string, params: list<string>) -> result<u64, string>;
    execute-batch: func(sql: string) -> result<u64, string>;
    transaction: func(statements: list<statement>) -> result<u64, string>;
    query: func(sql: string, params: list<string>) -> result<query-result, string>;
    query-typed: func(sql: string, params: list<string>) -> result<typed-query-result, string>;
}

interface postgres {
    variant postgres-value {
        null,
        integer(s64),
        float(f64),
        boolean(bool),
        text(string),
        bytes(list<u8>),
    }

    record statement {
        sql: string,
        params: list<postgres-value>,
    }

    record row {
        values: list<postgres-value>,
    }

    record query-result {
        columns: list<string>,
        rows: list<row>,
    }

    execute: func(sql: string, params: list<postgres-value>) -> result<u64, string>;
    query: func(sql: string, params: list<postgres-value>) -> result<query-result, string>;
    transaction: func(statements: list<statement>) -> result<u64, string>;
}

interface mysql {
    variant mysql-value {
        null,
        integer(s64),
        float(f64),
        boolean(bool),
        text(string),
        bytes(list<u8>),
    }

    record statement {
        sql: string,
        params: list<mysql-value>,
    }

    record row {
        values: list<mysql-value>,
    }

    record query-result {
        columns: list<string>,
        rows: list<row>,
    }

    execute: func(sql: string, params: list<mysql-value>) -> result<u64, string>;
    query: func(sql: string, params: list<mysql-value>) -> result<query-result, string>;
    transaction: func(statements: list<statement>) -> result<u64, string>;
}

interface object-store {
    record header {
        name: string,
        value: string,
    }

    record presign-upload-request {
        filename: string,
        content-type: string,
        size-bytes: u64,
        sha256: option<string>,
        expires-in-ms: option<u64>,
        visibility: option<string>,
    }

    record presigned-url {
        file-id: string,
        url: string,
        method: string,
        headers: list<header>,
        expires-at-ms: option<u64>,
        public-url: option<string>,
    }

    presign-upload: func(request: presign-upload-request) -> result<presigned-url, string>;
    presign-download: func(file-id: string, expires-in-ms: option<u64>) -> result<presigned-url, string>;
}

world imports {
    import sqlite;
    import postgres;
    import mysql;
    import object-store;
}
