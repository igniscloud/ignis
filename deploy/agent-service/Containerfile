FROM docker.io/library/node:24-bookworm-slim

ARG CODEX_NPM_VERSION=0.118.0
ARG PLAYWRIGHT_NPM_VERSION=1.58.2

ENV HOME=/agent-home \
    NODE_PATH=/opt/agent-service/node_modules \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    PATH=/agent-home/.local/bin:/usr/local/bin:${PATH}

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        chromium \
        curl \
        git \
        python3 \
        tini \
    && npm install -g \
        "@openai/codex@${CODEX_NPM_VERSION}" \
        "@openai/codex-linux-x64@npm:@openai/codex@${CODEX_NPM_VERSION}-linux-x64" \
    && mkdir -p /opt/agent-service /agent-home/.agents/skills /ms-playwright /app/config /app/data /app/work \
    && npm install --prefix /opt/agent-service --omit=dev \
        "playwright-core@${PLAYWRIGHT_NPM_VERSION}" \
        "playwright@${PLAYWRIGHT_NPM_VERSION}" \
    && /opt/agent-service/node_modules/.bin/playwright install chromium \
    && ln -sf /opt/agent-service/node_modules/.bin/playwright /usr/local/bin/playwright \
    && chmod -R 0777 /agent-home /ms-playwright /app/config /app/data /app/work \
    && rm -rf /root/.npm /agent-home/.npm /var/lib/apt/lists/*

COPY artifacts/agent-service /usr/local/bin/agent-service
COPY entrypoint.sh /usr/local/bin/agent-service-entrypoint.sh

RUN chmod +x /usr/local/bin/agent-service /usr/local/bin/agent-service-entrypoint.sh

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/agent-service-entrypoint.sh"]
