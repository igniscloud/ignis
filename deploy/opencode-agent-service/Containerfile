FROM docker.io/library/node:24-trixie-slim

ARG OPENCODE_NPM_VERSION=latest
ARG PLAYWRIGHT_NPM_VERSION=1.58.2

ENV HOME=/agent-home \
    NODE_PATH=/opt/opencode-agent-service/node_modules \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    PATH=/agent-home/.local/bin:/usr/local/bin:${PATH}

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        chromium \
        curl \
        git \
        python3 \
        tini \
    && npm install -g "opencode-ai@${OPENCODE_NPM_VERSION}" \
    && mkdir -p /opt/opencode-agent-service /agent-home/.config/opencode /ms-playwright /app/data /app/work \
    && npm install --prefix /opt/opencode-agent-service --omit=dev \
        "playwright-core@${PLAYWRIGHT_NPM_VERSION}" \
        "playwright@${PLAYWRIGHT_NPM_VERSION}" \
    && /opt/opencode-agent-service/node_modules/.bin/playwright install chromium \
    && ln -sf /opt/opencode-agent-service/node_modules/.bin/playwright /usr/local/bin/playwright \
    && chmod -R 0777 /agent-home /ms-playwright /app/data /app/work \
    && rm -rf /root/.npm /agent-home/.npm /var/lib/apt/lists/*

COPY artifacts/agent-service /usr/local/bin/agent-service
COPY entrypoint.sh /usr/local/bin/opencode-agent-service-entrypoint.sh

RUN chmod +x /usr/local/bin/agent-service /usr/local/bin/opencode-agent-service-entrypoint.sh

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/opencode-agent-service-entrypoint.sh"]
